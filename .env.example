# ─── Synthetic Cortex OS — Environment ──────────────────────────────────────

# Path where the telemetry state file is persisted.
# - Local dev default: ~/.claude/cortex-state.json
# - Railway / prod default: $TMPDIR/cortex-state.json
# Set this to override both.
# CORTEX_STATE_PATH=/var/data/cortex-state.json

# Bearer secret required for POST /api/cortex/state.
# If unset, POST is OPEN (only acceptable for local dev).
# Generate with: openssl rand -hex 32
# CORTEX_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Auto-set by Railway — do not set manually in dev.
# RAILWAY_ENVIRONMENT=production
